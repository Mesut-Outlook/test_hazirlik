# Geçici / yeniden üretilebilir dosyalar
.~lock.*#
__pycache__/
node_modules/
arayuz/backend/venv/
arayuz/ayarlar.json

# QA karşılaştırma görüntüleri (compare.py ile yeniden üretilebilir)
qa/cmp_*.png
qa/r2/
qa/r3/
qa/*.ppm
qa/text_diff.txt

# Üretilen HTML dosyaları (assemble.py ile yeniden üretilebilir)
temalar/*/*.html
